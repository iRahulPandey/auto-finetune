# Copy this file to .env and fill in your values.
# The app loads .env automatically on startup — no shell export needed.

# Required: get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default local MLflow tracking URI
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Optional: push trained adapters to HuggingFace Hub (get yours at https://huggingface.co/settings/tokens)
# HF_TOKEN=hf_...
